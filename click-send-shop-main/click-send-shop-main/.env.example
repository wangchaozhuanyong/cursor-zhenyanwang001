# Keep API same-origin in production.
VITE_API_BASE_URL=/api

# Upload storage policy:
# s3: require upload URL to be Amazon S3 / CloudFront (recommended)
# any: disable frontend storage check (not recommended)
VITE_UPLOAD_STORAGE=s3

# 图片 S3 预签名直传（ticket → PUT → complete）；默认关闭，上线前配好 S3/CORS 后再设 1
# VITE_UPLOAD_PRESIGN=0

# Optional allowlist for custom S3/CDN domains (comma separated).
# Example: VITE_S3_PUBLIC_HOSTS=cdn.example.com,d123abc.cloudfront.net
VITE_S3_PUBLIC_HOSTS=
