{
  "name": "click-send-shop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:shop": "vite build",
    "build:admin": "node scripts/build-admin.mjs",
    "build:legacy": "node scripts/build-legacy.mjs",
    "build:all": "node scripts/build-all.mjs",
    "build:all:legacy": "node scripts/build-all.mjs --legacy",
    "postbuild": "node scripts/fix-pwa-sw-location.mjs",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "typecheck:strict-api": "tsc -p tsconfig.strict-api.json --noEmit",
    "typecheck:strict-admin": "tsc -p tsconfig.strict-admin.json --noEmit",
    "test:storefront-products": "vitest run src/stores/useProductStore.test.ts",
    "preview": "vite preview",
    "preview:local": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "preview:local:4174": "vite preview --host 127.0.0.1 --port 4174 --strictPort",
    "test": "vitest run",
    "test:browser-compat": "vitest run --pool=threads --maxWorkers=1 src/lib/browserBoot.test.ts src/utils/browserEnv.test.ts src/components/support/InstallPlatformCard.test.tsx",
    "test:watch": "vitest",
    "smoke:restructure": "node scripts/smoke-restructure.mjs",
    "smoke:admin-auth-restructure": "node scripts/smoke-admin-auth-restructure.mjs",
    "regression:shots": "node scripts/regression-with-screenshots.mjs",
    "verify:theme-studio": "node scripts/verify-theme-studio.mjs",
    "theme:check": "node scripts/check-public-theme-hardcoded-colors.mjs",
    "check:mojibake": "node scripts/check-mojibake.mjs",
    "check:admin-i18n": "node scripts/check-admin-i18n-health.mjs",
    "check:api-paths": "node scripts/check-api-paths.mjs",
    "check:admin-labels": "node scripts/check-admin-label-registry.mjs",
    "check:routes": "node scripts/check-admin-route-access.mjs",
    "check:browser-compat": "node scripts/check-china-browser-compat.mjs",
    "check:china-browser": "node scripts/check-china-browser-compat.mjs",
    "i18n:admin": "python scripts/extract_admin_zh.py && python scripts/build_admin_zh_to_en.py",
    "i18n:admin:wrap": "node scripts/wrap_admin_tsx_i18n.mjs && node scripts/dedup-tx.mjs && node scripts/fix_module_level_ttext.mjs && node scripts/fix-broken-i18n-imports.mjs && npm run i18n:admin",
    "check:text": "npm run check:mojibake && npm run check:admin-i18n && npm run check:api-paths && npm run check:admin-labels && npm run check:routes && npm run check:browser-compat",
    "check:migrations": "node ../../server/scripts/check-migration-prefix-conflicts.js",
    "verify:dist": "node ../../scripts/verify_frontend_dist_assets.js dist && node ../../scripts/verify_frontend_dist_assets.js admin-dist && npm run verify:pwa",
    "verify:legacy-dist": "node scripts/verify-legacy-dist.mjs",
    "verify": "npm run typecheck && npm run typecheck:strict-api && npm run typecheck:strict-admin && npm run test:storefront-products && npm run check:text && npm run build",
    "prepare": "node scripts/install-git-hooks.mjs",
    "audit:overlap": "node scripts/audit-ui-overlap.mjs",
    "audit:overlap:full": "node scripts/audit-ui-overlap.mjs --full",
    "audit:route-transition": "node scripts/audit-route-transition.mjs",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "verify:pwa": "node scripts/verify-pwa.mjs",
    "acceptance:pwa-device": "node scripts/pwa-device-acceptance.mjs"
  },
  "browserslist": [
    "> 0.3%",
    "last 3 versions",
    "Chrome >= 64",
    "ChromeAndroid >= 64",
    "Edge >= 79",
    "Firefox >= 78",
    "Safari >= 12",
    "iOS >= 12",
    "Android >= 7",
    "Samsung >= 9",
    "not dead",
    "not IE 11"
  ],
  "dependencies": {
    "@imgly/background-removal": "^1.7.0",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@simplewebauthn/browser": "^13.3.0",
    "@tanstack/react-query": "^5.83.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.5",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.462.0",
    "next-themes": "^0.3.0",
    "onnxruntime-web": "^1.21.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@types/node": "^22.16.5",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-legacy": "^8.0.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "terser": "^5.47.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^8.0.11",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.8"
  }
}
