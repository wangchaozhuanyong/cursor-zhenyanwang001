{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowBackupWritesOnly",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectRetention",
        "s3:PutObjectLegalHold",
        "s3:AbortMultipartUpload"
      ],
      "Resource": "arn:aws:s3:::YOUR_BACKUP_BUCKET/shop-backups/*"
    },
    {
      "Sid": "AllowMinimalList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketVersioning",
        "s3:GetBucketObjectLockConfiguration"
      ],
      "Resource": "arn:aws:s3:::YOUR_BACKUP_BUCKET",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "shop-backups/*"
          ]
        }
      }
    },
    {
      "Sid": "DenyDeletesAndBypass",
      "Effect": "Deny",
      "Action": [
        "s3:DeleteObject",
        "s3:DeleteObjectVersion",
        "s3:BypassGovernanceRetention"
      ],
      "Resource": "arn:aws:s3:::YOUR_BACKUP_BUCKET/shop-backups/*"
    }
  ]
}
