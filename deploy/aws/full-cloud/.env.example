AWS_REGION=ap-southeast-1
AWS_PROFILE=default

# Network + compute
PROJECT_TAG=click-send-shop
VPC_CIDR=10.40.0.0/16
PUBLIC_SUBNET_A_CIDR=10.40.1.0/24
PUBLIC_SUBNET_B_CIDR=10.40.2.0/24
PRIVATE_SUBNET_A_CIDR=10.40.11.0/24
PRIVATE_SUBNET_B_CIDR=10.40.12.0/24
AZ_A=ap-southeast-1a
AZ_B=ap-southeast-1b
EC2_INSTANCE_TYPE=t3.small
EC2_KEY_NAME=replace_with_existing_keypair_name
EC2_AMI_ID=resolve_via_ssm
SSH_ALLOW_CIDR=0.0.0.0/0

# RDS
RDS_INSTANCE_CLASS=db.t4g.micro
RDS_ENGINE_VERSION=8.0.39
RDS_DB_NAME=click_send_shop
RDS_MASTER_USERNAME=admin
RDS_MASTER_PASSWORD=REPLACE_ME_STRONG_PASSWORD
RDS_ALLOCATED_STORAGE=20

# App + repo
PROJECT_DIR=/var/www/click-send-shop
REPO_URL=https://github.com/REPLACE_ME/REPLACE_ME.git
REPO_BRANCH=main
APP_PORT=3001
NODE_ENV=production
PUBLIC_APP_URL=https://example.com
CORS_ORIGINS=https://example.com
JWT_SECRET=CHANGE_ME_TO_YOUR_64PLUS_CHAR_RANDOM_SECRET_1234567890abcdef1234567890abcdef

# Existing source DB (local or remote) for migration
SOURCE_DB_HOST=127.0.0.1
SOURCE_DB_PORT=3306
SOURCE_DB_USER=root
SOURCE_DB_PASSWORD=REPLACE_ME
SOURCE_DB_NAME=click_send_shop

# Domain + DNS
DOMAIN_NAME=example.com
HOSTED_ZONE_CREATE=true
SUBDOMAIN=
CERT_EMAIL=admin@example.com

# Optional Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
