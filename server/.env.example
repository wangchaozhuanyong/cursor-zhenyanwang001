PORT=3000

# 位于 Nginx / 负载均衡之后时建议保留默认（生产且未设为 0 时 trust proxy=1）；直连公网 Node 可设 TRUST_PROXY=0
# TRUST_PROXY=1



# 生产环境：与 Node 同进程托管前端静态资源时设为 production

# NODE_ENV=production



# 前端构建目录（默认已指向仓库内 click-send-shop-main/dist）

# FRONTEND_DIST=



# 仅跑后端 API、不托管前端 dist 时设为 0（默认会托管同仓库下的前端构建产物）

# SERVE_SPA=0



# 逗号分隔；须包含用户访问前端的完整 Origin（含协议与端口）。禁止使用 *。

# 本地开发可保留 localhost；生产构建校验会拒绝 CORS 中含 localhost/127.0.0.1 与占位符。

CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:8080,http://localhost:8081,http://localhost:3000,http://127.0.0.1:3000,https://__SET_PRODUCTION_ORIGIN__

# 仅本地临时调试未知前端端口时开启；生产环境无效且不建议开启。
# ALLOW_DEV_CORS_ANY_ORIGIN=0



DB_HOST=localhost

DB_PORT=3306

DB_USER=root

DB_PASSWORD=

DB_NAME=click_send_shop



# 版本化迁移（up/down）：在 server 目录执行 npm run migrate | npm run migrate:status | npm run migrate:down

# 启动时也会自动执行未应用的迁移（见 src/index.js）



# 默认关闭首个注册用户自动升管理员，避免公网新实例被抢注接管。
# 如确需本地初始化便捷流程，可临时设为 1；生产建议使用 npm run admin:create。
# AUTO_PROMOTE_FIRST_USER_TO_ADMIN=0



# 至少 64 字符强随机；切勿提交真实密钥到版本库

JWT_SECRET=CHANGE_ME_TO_YOUR_64PLUS_CHAR_RANDOM_SECRET_FOR_DEV_AND_PROD_1234567890

JWT_EXPIRES_IN=7d



# 用户支付完成回跳、Stripe Checkout 成功/取消 URL 依赖此项；无尾部斜杠。

# 本地开发可用 http://localhost:5173；生产环境必须为 https 正式域名（见 validateEnv 校验）

# 须与用户访问前端的地址一致（本仓库 Vite 默认端口为 8080）
PUBLIC_APP_URL=http://localhost:8080

# OAuth（Google）redirect 回调须与控制台登记的「授权重定向 URI」完全一致。
# 本地示例：http://127.0.0.1:3000（与 PORT 一致，无尾部斜杠）
# OAUTH_CALLBACK_BASE_URL=http://127.0.0.1:3000
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=

# 微信开放平台网站应用扫码登录（AppSecret 仅后端使用，勿暴露给前端）
# 授权回调 URI 示例：http://127.0.0.1:3000/api/auth/wechat/callback
# WECHAT_OPEN_APP_ID=
# WECHAT_OPEN_APP_SECRET=
# 设为 1 才开放微信 / Google 第三方登录（前端 THIRD_PARTY_LOGIN_ENABLED 需同步）
# THIRD_PARTY_LOGIN_ENABLED=0

# 开发环境在响应中回显 OTP（勿用于生产）
# EXPOSE_OTP_CODE=true

# 生产环境短信 OTP：启用后必须配置真实供应商，否则发送接口会拒绝。
# 支持两种通道：
# 1) Twilio REST API
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# # 或使用 Messaging Service（与 TWILIO_FROM 二选一）
# TWILIO_MESSAGING_SERVICE_SID=
# 2) 通用 HTTP 网关（模板变量：{{phone}} / {{code}} / {{message}}）
# SMS_PROVIDER=http
# SMS_HTTP_URL=https://sms-provider.example/send
# SMS_HTTP_METHOD=POST
# SMS_HTTP_HEADERS_JSON={"Authorization":"Bearer xxx"}
# SMS_HTTP_BODY_TEMPLATE={"to":"{{phone}}","message":"{{message}}"}
# # 可选：响应正文必须匹配才视为成功
# SMS_HTTP_SUCCESS_REGEX="\"success\"\\s*:\\s*true"
# SMS_OTP_MESSAGE_TEMPLATE=Your verification code is {{code}}. It expires in 5 minutes.
# OTP_MAX_PER_IP_PER_HOUR=30
# SMS_LOGIN_ENABLED=1


# —— 订单超时关单（释放未支付订单占用的库存/活动销量/优惠券）
# 默认关闭，生产启用前请确认支付回调与关单时长策略。
# 也可在 site_settings 中配置 orderPaymentTimeoutEnabled / orderPaymentTimeoutMinutes 覆盖。
# ORDER_PAYMENT_TIMEOUT_ENABLED=1
# ORDER_PAYMENT_TIMEOUT_MINUTES=30
# ORDER_PAYMENT_TIMEOUT_INTERVAL_MS=300000



# —— Stripe（启用真实收款时二者必填；Webhook: POST /api/payment/stripe/webhook）

# STRIPE_SECRET_KEY=

# STRIPE_WEBHOOK_SECRET=


# —— Malaysia LHDN MyInvois（默认关闭；仅公司被要求或明确计划对接时开启）
# MYINVOIS_ENABLED=0
# sandbox/live；正式提交前需法务/会计完成 LHDN 测试环境验收
# MYINVOIS_SUBMIT_ENABLED=0
# MYINVOIS_API_BASE_URL=
# MYINVOIS_RETRY_INTERVAL_MS=300000


# —— Cloudflare 缓存刷新（deploy/purge-cloudflare-cache.sh / ci-deploy 可选）
# 在 Cloudflare 控制台 → 我的个人资料 → API 令牌 → 创建「缓存清除」权限的 Token
# Zone ID：域名 Overview 页右侧栏
# CF_API_TOKEN=
# CF_ZONE_ID=
# CF_PURGE_MODE=urls
# CF_PURGE_URLS=https://flashcast.com.my/favicon.ico,https://flashcast.com.my/favicon.webp


# —— 对象存储（Logo/Favicon 推荐生产启用）
# STORAGE_DRIVER=s3 时，站点图片会上传到 OSS/S3，数据库仅保存 URL
# STORAGE_DRIVER 留空或非 s3 时，站点图片按 dataURL 保存到数据库（开发兜底）
# STORAGE_DRIVER=s3
# STORAGE_S3_ENDPOINT=
# STORAGE_S3_REGION=auto
# STORAGE_S3_BUCKET=
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=
# STORAGE_S3_FORCE_PATH_STYLE=false
# STORAGE_PUBLIC_BASE_URL=
# STORAGE_KEY_PREFIX=prod
# 预签名直传 S3（仅 STORAGE_DRIVER=s3）：POST /api/upload/ticket → PUT S3 → POST /api/upload/complete
# UPLOAD_PRESIGN_EXPIRES_SEC=300

