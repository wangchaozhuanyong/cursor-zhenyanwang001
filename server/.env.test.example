# Copy to .env.test for local/CI database integration tests.
# Do not point this file at production data.

NODE_ENV=test
PORT=3000

PUBLIC_APP_URL=http://127.0.0.1:8080
CORS_ORIGINS=http://127.0.0.1:8080,http://127.0.0.1:3000
ADMIN_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://127.0.0.1:3000

DB_HOST=<aws-test-db-endpoint>
DB_PORT=3306
DB_USER=<test-db-user>
DB_PASSWORD=<test-db-password>
DB_NAME=click_send_shop_test

JWT_SECRET=change-me-for-tests
ADMIN_MFA_SECRET_KEY=change-me-for-tests
ADMIN_MFA_ISSUER=ClickSendShop Test Admin
ADMIN_JWT_EXPIRES_IN=15m
ADMIN_LOGIN_CAPTCHA_FAILURES=3
ADMIN_LOGIN_LOCK_FAILURES=10
ADMIN_LOGIN_LOCK_MINUTES=30

# Keep this disabled. Enable only for intentionally testing against a database
# name that does not include test/ci/dev/staging.
ALLOW_PRODUCTION_DB_TESTS=0
