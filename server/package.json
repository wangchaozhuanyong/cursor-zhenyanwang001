{
  "name": "click-send-shop-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "start:prod": "cross-env NODE_ENV=production node src/index.js",
    "dev": "nodemon src/index.js",
    "dev:local": "cross-env DB_PASSWORD= nodemon src/index.js",
    "db:init": "node scripts/apply-sql.js",
    "admin:create": "node scripts/create-admin.js",
    "admin:role": "node scripts/set-admin-role.js",
    "migrate": "node scripts/migrate-cli.js",
    "migrate:down": "node scripts/migrate-cli.js down",
    "migrate:status": "node scripts/migrate-cli.js status",
    "test": "node --test test/health.test.js",
    "test:integration": "node --test test/auth-flow.test.js",
    "test:flow": "node --test test/flow-smoke.test.js",
    "test:smoke": "node --test test/flow-smoke.test.js",
    "test:stripe": "node --test test/stripe-amount.test.js",
    "test:all": "node --test --test-force-exit test/health.test.js test/auth-flow.test.js test/flow-smoke.test.js test/stripe-amount.test.js test/order-state-machine.test.js test/return-state-machine.test.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "stripe": "^17.7.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4"
  }
}
