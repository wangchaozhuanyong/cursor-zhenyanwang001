{
  "name": "click-send-shop-server",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node src/index.js",
    "start:prod": "cross-env NODE_ENV=production node src/index.js",
    "dev": "nodemon --exec \"node -r tsx/cjs\" src/index.js",
    "dev:local": "nodemon --exec \"node -r tsx/cjs\" src/index.js",
    "typecheck": "tsc --noEmit",
    "check:service-layer": "node scripts/check-service-layer.js",
    "check:module-structure": "node scripts/check-module-structure.js",
    "check:tracked-artifacts": "node scripts/check-tracked-artifacts.js",
    "db:init": "node scripts/migrate-cli.js up",
    "db:create-test": "node scripts/create-test-database.js --migrate",
    "db:grant-test": "node scripts/grant-test-database.js",
    "admin:create": "node scripts/create-admin.js",
    "admin:role": "node scripts/set-admin-role.js",
    "migrate": "node scripts/migrate-cli.js",
    "migrate:down": "node scripts/migrate-cli.js down",
    "migrate:status": "node scripts/migrate-cli.js status",
    "verify-schema": "node scripts/verify-critical-schema.js",
    "backup:full": "node scripts/backup/backup-full.js",
    "backup:binlog": "node scripts/backup/backup-binlog-sync.js",
    "backup:config": "node scripts/backup/backup-config.js",
    "restore:temp": "node scripts/backup/restore-to-temp.js",
    "restore:drill": "node scripts/backup/restore-drill.js",
    "wipe:business-data": "node scripts/wipe-business-data.js",
    "purge:demo-products": "node scripts/purge-demo-products.js",
    "seed:content-pages": "node scripts/seed-content-pages.js",
    "seed:policy-paths": "node scripts/seed-policy-paths.js",
    "seed:products": "node scripts/seed-products.js",
    "smoke:user-tag-marketing": "node scripts/smoke-user-tag-marketing.js",
    "test": "npm run test:unit",
    "test:redis": "node -r tsx/cjs --test test/redis-standard.test.js",
    "test:integration": "node scripts/run-db-integration-tests.js test/auth-flow.test.js test/payment-channels.test.js test/admin-user-tags.test.js",
    "test:flow": "node scripts/run-db-integration-tests.js test/flow-smoke.test.js",
    "test:smoke": "node scripts/run-db-integration-tests.js test/flow-smoke.test.js",
    "test:stripe": "node -r tsx/cjs --test test/stripe-amount.test.js",
    "test:unit": "node -r tsx/cjs --test --test-force-exit test/health.test.js test/stripe-amount.test.js test/order-state-machine.test.js test/order-summary.test.js test/return-state-machine.test.js test/file-magic.test.js test/upload-presign.test.js test/sms-otp-adapter.test.js test/auth-cookies.test.js test/manual-webhook-security.test.js test/cms-sanitize.test.js test/admin-order-schemas.test.js test/points-engine.test.js test/points-bonus.test.js test/birthday-window.test.js test/order-points.test.js test/sign-in-timezone.test.js test/points-adjust.test.js test/points-expire.test.js test/points-loyalty-hints.test.js test/monitoring-cron.test.js test/monitoring-auto-fix.test.js test/admin-gateway-guard.test.js test/admin-event-service.test.js test/data-retention-service.test.js test/admin-product-high-risk-routes.test.js test/rbac-authorization.test.js",
    "test:integration": "node scripts/run-db-integration-tests.js test/auth-flow.test.js test/payment-channels.test.js test/admin-user-tags.test.js test/admin-product-soft-delete.test.js test/rbac-authorization.test.js test/order-pay-capability.test.js",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:smoke"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.6",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "mysql2": "^3.20.0",
    "sanitize-html": "^2.17.4",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
