{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022"],
    "rootDir": "src",
    "outDir": "dist",

    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noUncheckedIndexedAccess": false,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": false,
    "useUnknownInCatchVariables": false,

    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,

    "declaration": false,
    "sourceMap": true,
    "removeComments": false
  },
  "include": [
    "src/types/**/*.d.ts",
    "src/config/**/*.js",
    "src/constants/**/*.js",
    "src/errors/**/*.js",
    "src/middleware/**/*.js",
    "src/utils/**/*.js",
    "src/modules/auth/**/*.js",
    "src/modules/admin/controller/**/*.js",
    "src/modules/admin/*.service.js",
    "src/modules/admin/*.repository.js",
    "src/modules/admin/admin.routes.js",
    "src/modules/admin/index.js",
    "src/modules/admin/notificationTriggerApi.js",
    "src/modules/order/**/*.js",
    "src/modules/cart/**/*.js",
    "src/modules/product/**/*.js",
    "src/modules/user/**/*.js",
    "src/modules/health/**/*.js",
    "src/routes/index.js",
    "src/app.js",
    "src/index.js",
    "src/db/migrateRunner.js",
    "src/application/**/*.js"
  ],
  "exclude": ["node_modules", "dist", "test", "scripts"]
}
